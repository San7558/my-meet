PORT=5000
CLIENT_URL=http://localhost:5173

# ─── MongoDB Atlas ──────────────────────────────────────────────
MONGODB_URI=

# ─── Firebase Admin SDK ────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Deepgram ──────────────────────────────────────────────────
# Server-side key used to issue short-lived browser WebSocket tokens.
# Same key as VITE_DEEPGRAM_API_KEY in client/.env, but lives here
# so the master key is never exposed to the browser.
DEEPGRAM_API_KEY=

# ─── LibreTranslate (legacy, not used) ────────────────────────
# LIBRETRANSLATE_URL=http://localhost:5001
# LIBRETRANSLATE_API_KEY=
